# Nginx Configuration for fyxi.ru (Nuxt 3 SSR + Fastify REST API)

server {
    listen 80;
    server_name fyxi.ru www.fyxi.ru;
    return 301 https://fyxi.ru$request_uri;
}

server {
    listen 443 ssl http2;
    server_name www.fyxi.ru;

    # SSL Certificates
    ssl_certificate /etc/letsencrypt/live/fyxi.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fyxi.ru/privkey.pem;

    return 301 https://fyxi.ru$request_uri;
}

server {
    listen 443 ssl http2;
    server_name fyxi.ru;

    # SSL Certificates
    ssl_certificate /etc/letsencrypt/live/fyxi.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fyxi.ru/privkey.pem;

    # Performance: Gzip Compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    # 1. Direct Static Assets for Nuxt 3 Build Files (_nuxt/*.js, _nuxt/*.css)
    # FIXES ENOENT 500 errors: Nginx directly serves static chunks and returns clean 404 for outdated browser sessions
    location /_nuxt/ {
        alias /var/www/fyxi/frontend/.output/public/_nuxt/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # 2. Uploaded Avatar & Portfolio Images (/api/uploads/)
    location /api/uploads/ {
        alias /var/www/fyxi/backend/uploads/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
        try_files $uri =404;
    }

    # 2. Fastify REST API Proxy
    location /api/ {
        proxy_pass http://127.0.0.1:5010/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # 3. Nuxt 3 SSR Application Proxy
    location / {
        proxy_pass http://127.0.0.1:5011;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
